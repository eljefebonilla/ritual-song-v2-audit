  "readings": [
    {
      "type": "first",
      "citation": "Jer 33:14-16",
      "summary": "The day is coming when the Lord will fulfill his promises."
    },
    {
      "type": "psalm",
      "citation": "Ps 25:4-5, 8-9, 10, 14, R. v.1b\nTo you, O Lord, I lift my soul.",
      "summary": "",
      "antiphon": "Ps 25:4-5, 8-9, 10, 14, R. v.1b\nTo you, O Lord, I lift my soul."
    },
    {
      "type": "second",
      "citation": "1 Thes 3:12 – 4:2",
      "summary": "Conduct yourself in a way pleasing to God."
    },
    {
      "type": "gospel_verse",
      "citation": "cf. Ps 85:8",
      "summary": "Lord, show us your love; and grant us your salvation."
    },
    {
      "type": "gospel",
      "citation": "| Lk 21:25-28, 34-36",
      "summary": "Be ready for the second coming."
    }
  ],
  "antiphons": [
    {
      "type": "entrance",
      "option": 1,
      "citation": "Cf. Ps 25 (24):1–3",
      "text": "To you, I lift up my soul, O my God.\nIn you, I have trusted; let me not be put to shame.\nNor let my enemies exult over me; and let none who hope in you be put to shame."
    },
    {
      "type": "communion",
      "option": 1,
      "citation": "Ps 85 (84):13]",
      "text": "The Lord will bestow his bounty,\nand our earth shall yield its increase."
    }
  ],
