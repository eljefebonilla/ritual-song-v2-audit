    {
      "type": "communion",
      "option": 1,
      "citation": "Wis 16:20",
      "text": "You have given us, O Lord, bread from heaven,\nendowed with all delights and sweetness in every taste."
    },
    {
      "type": "communion",
      "option": 2,
      "citation": "Roman Missal — Jn 6:35",
      "text": "I am the bread of life, says the Lord;\nwhoever comes to me will not hunger\nand whoever believes in me will not thirst."
    }
