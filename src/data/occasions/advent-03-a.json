  "lectionary": {
    "number": "007•A",
    "gospelTitle": "Are You the One?",
    "thematicTag": "Baptist Call 2/2 — Messiah ID"
  },
  "readings": [
    {
      "type": "first",
      "citation": "Is 35:1-6a, 10",
      "summary": "The desert will rejoice and blossom."
    },
    {
      "type": "psalm",
      "citation": "Ps 146:6-7, 8-9, 9-10, R. see Is 35:4\nLord, come and save us.",
      "summary": "",
      "antiphon": "Ps 146:6-7, 8-9, 9-10, R. see Is 35:4\nLord, come and save us."
    },
    {
      "type": "second",
      "citation": "Jas 5:7-10",
      "summary": "Be patient, even in suffering."
    },
    {
      "type": "gospel_verse",
      "citation": "Is 61:1 (cited in Lk 4:18)",
      "summary": "The Spirit of the Lord is upon me,\nbecause he has anointed me\nto bring glad tidings to the poor."
    },
    {
      "type": "gospel",
      "citation": "Mt 11:2-11",
      "summary": "John asks, \"Are you the one who is to come?\""
    }
  ],
  "antiphons": [
    {
      "type": "entrance",
      "option": 1,
      "citation": "Phil 4:4–5",
      "text": "Rejoice in the Lord always;\nagain I say, rejoice.\nIndeed, the Lord is near."
    },
    {
      "type": "communion",
      "option": 1,
      "citation": "Cf. Is 35:4",
      "text": "Say to the faint of heart: Be strong and do not fear.\nBehold, our God will come, and he will save us."
    }
  ],
