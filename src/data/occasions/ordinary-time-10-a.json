  "readings": [
    {
      "type": "first",
      "citation": "Hos 6:3–6",
      "summary": "It is love that I desire, not sacrifice."
    },
    {
      "type": "psalm",
      "citation": "Ps 50:1, 8, 12–13, 14–15\nTo the upright I will show the saving power of God.",
      "summary": "",
      "antiphon": "Ps 50:1, 8, 12–13, 14–15\nTo the upright I will show the saving power of God."
    },
    {
      "type": "second",
      "citation": "Rom 4:18–25",
      "summary": "Abraham was strengthened by faith and gave glory to God."
    },
    {
      "type": "gospel_verse",
      "citation": "cf. Lk 4:18",
      "summary": "The Lord sent me to bring glad tidings to the poor,\nand to proclaim liberty to captives."
    },
    {
      "type": "gospel",
      "citation": "Mt 9:9–13",
      "summary": "I did not come to call the righteous but sinners."
    }
  ],
  "antiphons": [
    {
      "type": "entrance",
      "option": 1,
      "citation": "Cf. Ps 27 (26):1–2",
      "text": "The Lord is my light and my salvation; whom shall I fear?\nThe Lord is the stronghold of my life; whom should I dread?\nWhen those who do evil draw near, they stumble and fall."
    },
    {
      "type": "communion",
      "option": 1,
      "citation": "Ps 18 (17):3",
      "text": "The Lord is my rock, my fortress, and my deliverer;\nmy God is my saving strength."
    },
    {
      "type": "communion",
      "option": 2,
      "citation": "Communion Antiphon • Option II | 1 Jn 4:16",
      "text": "God is love, and whoever abides in love\nabides in God, and God in him."
    }
  ],
