      "citation": "Jas 2:14-18",
      "summary": "Faith without action is useless."
    },
    {
      "type": "gospel_verse",
      "citation": "Gal 6:14",
      "summary": "May I never boast except in the cross of our Lord\nthrough which the world has been crucified to me and I to the world."
    },
    {
      "type": "gospel",
      "citation": "Mk 8:27-35",
      "summary": "A follower of Christ must take up the cross."
    }
