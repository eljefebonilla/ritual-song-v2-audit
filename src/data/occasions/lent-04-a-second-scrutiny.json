      "type": "psalm",
      "citation": "Ps 23: 1-3a, 3b-4, 5, 6. R. v.1\nThe Lord is my shepherd; there is nothing I shall want.",
      "summary": "",
      "antiphon": "Ps 23: 1-3a, 3b-4, 5, 6. R. v.1\nThe Lord is my shepherd; there is nothing I shall want."
    },
    {
      "type": "second",
      "citation": "Eph 5:8-14",
      "summary": "Live in the light."
    },
    {
      "type": "gospel_verse",
      "citation": "Jn 8:12",
      "summary": "I am the light of the world, says the Lord;\nwhoever follows me will have the light of life."
    },
    {
      "type": "gospel",
      "citation": "Jn 9:1-41 (Shorter - Jn 9:1, 6-9, 13-17, 34-38)",
      "summary": "Jesus cures a blind man on the sabbath."
    }
  ],
  "antiphons": [
    {
      "type": "entrance",
      "option": 1,
      "citation": "Cf. Is 66:10–11",
      "text": "Rejoice, Jerusalem, and all who love her.\nBe joyful, all who were in mourning;\nexult and be satisfied at her consoling breast."
    },
    {
      "type": "communion",
      "option": 1,
      "citation": "For Jn 9:11, 38 (Man Born Blind)",
      "text": "The Lord anointed my eyes: I went, I washed,\nI saw and I believed in God."
    }
  ],
