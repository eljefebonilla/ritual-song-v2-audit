  "readings": [
    {
      "type": "first",
      "citation": "1 Kgs 17:17–24",
      "summary": "See! Your son is alive."
    },
    {
      "type": "psalm",
      "citation": "Ps 30:2, 4, 5–6, 11, 12, 13\nI will praise you, Lord, for you have rescued me.",
      "summary": "",
      "antiphon": "Ps 30:2, 4, 5–6, 11, 12, 13\nI will praise you, Lord, for you have rescued me."
    },
    {
      "type": "second",
      "citation": "Gal 1:11–19",
      "summary": "God revealed his Son to me, so that I might proclaim him to the Gentiles."
    },
    {
      "type": "gospel_verse",
      "citation": "Lk 7:16",
      "summary": "A great prophet has risen in our midst\nGod has visited his people."
    },
    {
      "type": "gospel",
      "citation": "Lk 7:11–17",
      "summary": "Young man, I tell you, arise!"
    }
  ],
  "antiphons": [
    {
      "type": "entrance",
      "option": 1,
      "citation": "Cf. Ps 27 (26):1–2",
      "text": "The Lord is my light and my salvation; whom shall I fear?\nThe Lord is the stronghold of my life; whom should I dread?\nWhen those who do evil draw near, they stumble and fall."
    },
    {
      "type": "communion",
      "option": 1,
      "citation": "Ps 18 (17):3",
      "text": "The Lord is my rock, my fortress, and my deliverer;\nmy God is my saving strength."
    },
    {
      "type": "communion",
      "option": 2,
      "citation": "Communion Antiphon • Option II | 1 Jn 4:16",
      "text": "God is love, and whoever abides in love\nabides in God, and God in him."
    }
  ],
