      "type": "first",
      "citation": "Dt 11:18, 26–28, 32",
      "summary": "I set before you here this day a blessing and a curse."
    },
    {
      "type": "psalm",
      "citation": "Ps 31:2–3, 3–4, 17, 25\nLord, be my rock of safety.",
      "summary": "",
      "antiphon": "Ps 31:2–3, 3–4, 17, 25\nLord, be my rock of safety."
    },
    {
      "type": "second",
      "citation": "Rom 3:21–25, 28",
      "summary": "A person is justified by faith apart from works of the law."
    },
    {
      "type": "gospel_verse",
      "citation": "Jn 15:5",
      "summary": "I am the vine, you are the branches, says the Lord;\nwhoever remains in me and I in him will bear much fruit."
    },
    {
      "type": "gospel",
      "citation": "Mt 7:21–27",
      "summary": "The house built on rock, and the house built on sand."
    }
  ],
  "antiphons": [
    {
      "type": "entrance",
      "option": 1,
      "citation": "Cf. Ps 25 (24):16, 18",
      "text": "Turn to me and have mercy on me, O Lord,\nfor I am alone and poor.\nSee my lowliness and suffering\nand take away all my sins, my God"
    },
    {
      "type": "communion",
      "option": 1,
      "citation": "Cf. Ps 17 (16):6]",
      "text": "To you I call, for you will surely heed me, O God;\nturn your ear to me; hear my words."
    },
    {
      "type": "communion",
      "option": 2,
      "citation": "Communion Antiphon • Option II | Mk 11:23, 24",
      "text": "Amen, I say to you: Whatever you ask for in prayer,\nbelieve you will receive it,\nand it will be yours, says the Lord."
    }
  ],
