  },
  "readings": [
    {
      "type": "first",
      "citation": "Is 2:1–5",
      "summary": "All nations shall stream to the mountain of the Lord."
    },
    {
      "type": "psalm",
      "citation": "Ps 122:1-2, 3-4, 4-5, 6-7, 8-9\nLet us go rejoicing to the house of the Lord.",
      "summary": "",
      "antiphon": "Ps 122:1-2, 3-4, 4-5, 6-7, 8-9\nLet us go rejoicing to the house of the Lord."
    },
    {
      "type": "second",
      "citation": "Rom 13:11-14",
      "summary": "Live honorably, the day of the Lord is near."
    },
    {
      "type": "gospel_verse",
      "citation": "cf. Ps 85:8",
      "summary": "Lord, show us your love; and grant us your salvation."
    },
    {
      "type": "gospel",
      "citation": "Mt 24:37-44",
      "summary": "The Lord is coming when we least expect."
    }
  ],
  "antiphons": [
    {
      "type": "entrance",
      "option": 1,
      "citation": "Cf. Ps 25 (24):1–3",
      "text": "To you, I lift up my soul, O my God.\nIn you, I have trusted; let me not be put to shame.\nNor let my enemies exult over me; and let none who hope in you be put to shame."
    },
    {
      "type": "communion",
      "option": 1,
      "citation": "Ps 85 (84):13]",
      "text": "The Lord will bestow his bounty,\nand our earth shall yield its increase."
    }
  ],
