  "readings": [
    {
      "type": "first",
      "citation": "Wis 11:22 – 12:2",
      "summary": "The Lord loves all creation."
    },
    {
      "type": "psalm",
      "citation": "Ps 145:1-2, 8-9, 10-11, 13, 14, R. see v.1\nI will praise your name for ever, my king and my God.",
      "summary": "",
      "antiphon": "Ps 145:1-2, 8-9, 10-11, 13, 14, R. see v.1\nI will praise your name for ever, my king and my God."
    },
    {
      "type": "second",
      "citation": "2 Thes 1:11-2:2",
      "summary": "The day of the Lord is not yet here."
    },
    {
      "type": "gospel_verse",
      "citation": "Jn 3:16",
      "summary": "God so loved the world that he gave his only Son,\nso that everyone who believes in him might have eternal life."
    },
    {
      "type": "gospel",
      "citation": "Lk 19:1-10",
      "summary": "Jesus enters the house of Zacchaeus."
    }
  ],
  "antiphons": [
    {
      "type": "entrance",
      "option": 1,
      "citation": "Cf. Ps 38 (37):22–23",
      "text": "Forsake me not, O Lord, my God;\nbe not far from me!\nMake haste and come to my help,\nO Lord, my strong salvation!"
    },
    {
      "type": "communion",
      "option": 1,
      "citation": "Cf. Ps 16 (15):11",
      "text": "You will show me the path of life,\nthe fullness of joy in your presence, O Lord."
    },
    {
      "type": "communion",
      "option": 2,
      "citation": "Roman Missal — Jn 6:58",
      "text": "Just as the living Father sent me\nand I have life because of the Father,\nso whoever feeds on me\nshall have life because of me, says the Lord."
    }
  ],
