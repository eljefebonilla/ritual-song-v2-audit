      "type": "first",
      "citation": "Dt 5:12–15",
      "summary": "Remember that you too were once a slave in Egypt."
    },
    {
      "type": "psalm",
      "citation": "Ps 81:3–4, 5–6, 6–8, 10–11\nSing with joy to God our help.",
      "summary": "",
      "antiphon": "Ps 81:3–4, 5–6, 6–8, 10–11\nSing with joy to God our help."
    },
    {
      "type": "second",
      "citation": "2 Cor 4:6–11",
      "summary": "The life of Jesus is manifested in our body."
    },
    {
      "type": "gospel_verse",
      "citation": "cf. Jn 17:17b, 17a",
      "summary": "Your word, O Lord, is truth; consecrate us in the truth."
    },
    {
      "type": "gospel",
      "citation": "Mk 2:23–3:6 (Shorter - Mk 2:23–28)",
      "summary": "The Son of Man is lord even of the sabbath."
    }
  ],
  "antiphons": [
    {
      "type": "entrance",
      "option": 1,
      "citation": "Cf. Ps 25 (24):16, 18",
      "text": "Turn to me and have mercy on me, O Lord,\nfor I am alone and poor.\nSee my lowliness and suffering\nand take away all my sins, my God"
    },
    {
      "type": "communion",
      "option": 1,
      "citation": "Cf. Ps 17 (16):6]",
      "text": "To you I call, for you will surely heed me, O God;\nturn your ear to me; hear my words."
    },
    {
      "type": "communion",
      "option": 2,
      "citation": "Communion Antiphon • Option II | Mk 11:23, 24",
      "text": "Amen, I say to you: Whatever you ask for in prayer,\nbelieve you will receive it,\nand it will be yours, says the Lord."
    }
  ],
