      "option": 1,
      "citation": "Cf. Ps 96 (95):1, 6",
      "text": "O sing a new song to the Lord;\nsing to the Lord, all the earth.\nIn his presence are majesty and splendor,\nstrength and honor in his holy place."
    },
    {
      "type": "communion",
      "option": 1,
      "citation": "Cf. Ps 34 (33):6",
      "text": "Look toward the Lord and be radiant;\nlet your faces not be abashed."
    },
    {
      "type": "communion",
      "option": 2,
      "citation": "Communion Antiphon • Option II | Cf. Jn 8:12",
      "text": "I am the light of the world, says the Lord;\nwhoever follows me will not walk in darkness,\nbut will have the light of life."
    }
