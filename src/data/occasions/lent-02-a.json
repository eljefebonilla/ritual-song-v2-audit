  "readings": [
    {
      "type": "first",
      "citation": "Gen 12:1-4a",
      "summary": "Abram leaves home receiving promises from the Lord."
    },
    {
      "type": "psalm",
      "citation": "Ps 33:4-5, 18-19, 20, 22. R. v.22\nLord, let your mercy be on us, as we place our trust in you.",
      "summary": "",
      "antiphon": "Ps 33:4-5, 18-19, 20, 22. R. v.22\nLord, let your mercy be on us, as we place our trust in you."
    },
    {
      "type": "second",
      "citation": "2 Tm 1:8b-10",
      "summary": "Following the Gospel entails some hardship."
    },
    {
      "type": "gospel_verse",
      "citation": "Mt 17:5",
      "summary": "From the shining cloud the Father’s voice is heard:\nThis is my beloved Son, hear him."
    },
    {
      "type": "gospel",
      "citation": "Mt 17:1-9",
      "summary": "Jesus is transfigured before Peter, James, and John."
    }
  ],
  "antiphons": [
    {
      "type": "entrance",
      "option": 1,
      "citation": "Cf. Ps 27 (26):8–9]",
      "text": "Of you my heart has spoken: Seek his face.\nIt is your face, O Lord, that I seek;\nhide not your face from me."
    },
    {
      "type": "entrance",
      "option": 2,
      "citation": "Entrance Antiphon • Option II | Ps 25 (24):6, 2, 22",
      "text": "Remember your compassion, O Lord,\nand your merciful love, for they are from of old.\nLet not our enemies exult over us.\nRedeem us, O God of Israel, from all our distress."
    },
    {
      "type": "communion",
      "option": 1,
      "citation": "Cf. Mt 17:5",
      "text": "This is my beloved Son, with whom I am well pleased;\nlisten to him."
    }
  ],
  "planningNotes": [
    "FEB - Black History Month"
  ],
