  "readings": [
    {
      "type": "first",
      "citation": "Ex 20:1-17 (Shorter - Ex 20:1-3, 7-8, 12-17",
      "summary": "The Lord delivers the Ten Commandments."
    },
    {
      "type": "psalm",
      "citation": "Ps 19:8, 9, 10, 11, R. Jn 6:68\nLord, you have the words of everlasting life.",
      "summary": "",
      "antiphon": "Ps 19:8, 9, 10, 11, R. Jn 6:68\nLord, you have the words of everlasting life."
    },
    {
      "type": "second",
      "citation": "1 Cor 1:22-25",
      "summary": "Understand the power of Christ crucified."
    },
    {
      "type": "gospel_verse",
      "citation": "Jn 3:16",
      "summary": "God so loved the world that he gave his only Son,\nso everyone who believes in him might have eternal life."
    },
    {
      "type": "gospel",
      "citation": "Jn 2:13-25",
      "summary": "Jesus drives the money-changers from the temple."
    }
  ],
  "antiphons": [
    {
      "type": "entrance",
      "option": 1,
      "citation": "Cf. Ps 25 (24):15–16]",
      "text": "My eyes are always on the Lord,\nfor he rescues my feet from the snare.\nTurn to me and have mercy on me,\nfor I am alone and poor."
    },
    {
      "type": "entrance",
      "option": 2,
      "citation": "Entrance Antiphon • Option II | Cf. Ez 36:23–26",
      "text": "When I prove my holiness among you,\nI will gather you from all the foreign lands;\nand I will pour clean water upon you\nand cleanse you from all your impurities,\nand I will give you a new spirit, says the Lord."
    },
    {
      "type": "communion",
      "option": 1,
      "citation": "Years B & C - Ps 84 (83):4–5",
      "text": "The sparrow finds a home, and the swallow a nest for her young: by your altars, O Lord of hosts, my King and my God. Blessed are they who dwell in your house, for ever singing your praise."
    }
  ],
