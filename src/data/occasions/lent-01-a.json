  "lectionary": {
    "number": "022•A",
    "gospelTitle": "Jesus Is Tempted in the Desert",
    "thematicTag": "New Adam Tested"
  },
  "readings": [
    {
      "type": "first",
      "citation": "Gen 2:7-9; 3:1-7",
      "summary": "The Lord creates man and the garden of Eden."
    },
    {
      "type": "psalm",
      "citation": "Ps 51:3-4, 5-6, 12-13, 17. R. see v.3a\nBe merciful, O Lord, for we have sinned.",
      "summary": "",
      "antiphon": "Ps 51:3-4, 5-6, 12-13, 17. R. see v.3a\nBe merciful, O Lord, for we have sinned."
    },
    {
      "type": "second",
      "citation": "Rom 5:12-19 (Shorter - Rom 5:12, 17-19)",
      "summary": "Jesus has attoned for Adam\nDeath reigned until Christ came to atone for sin."
    },
    {
      "type": "gospel_verse",
      "citation": "Mt 4:4b",
      "summary": "One does not live on bread alone, but on every word\nthat comes forth from the mouth of God."
    },
    {
      "type": "gospel",
      "citation": "Mt 4:1-11",
      "summary": "Jesus is tempted by the devil in the desert."
    }
  ],
  "antiphons": [
    {
      "type": "entrance",
      "option": 1,
      "citation": "Cf. Ps 91 (90):15–16",
      "text": "When he calls on me, I will answer him;\nI will deliver him and give him glory,\nI will grant him length of days."
    },
    {
      "type": "communion",
      "option": 1,
      "citation": "Cf. Mt 4:4",
      "text": "One does not live by bread alone, but by every word\nthat comes forth from the mouth of God."
    },
    {
      "type": "communion",
      "option": 2,
      "citation": "Communion Antiphon • Option II | Cf. Ps 91 (90):4",
      "text": "The Lord will conceal you with his pinions,\nand under his wings you will trust."
    }
  ],
  "planningNotes": [
