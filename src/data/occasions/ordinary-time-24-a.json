      "type": "first",
      "citation": "Sir 27:30–28:7",
      "summary": "Hate and anger lead to death;\nlove and forgiveness to the kingdom."
    },
    {
      "type": "psalm",
      "citation": "Ps 103:1-2, 3-4, 9-10, 11-12. R. v.8\nThe Lord is kind and merciful, slow to anger, \nand rich in compassion.",
      "summary": "",
      "antiphon": "Ps 103:1-2, 3-4, 9-10, 11-12. R. v.8\nThe Lord is kind and merciful, slow to anger, \nand rich in compassion."
    },
    {
      "type": "second",
      "citation": "Rom 14:7-9",
      "summary": "Christ is Lord of the living and the dead."
    },
    {
      "type": "gospel_verse",
      "citation": "Jn 13:34",
      "summary": "I give you a new commandment, says the Lord;\nlove one another as I have loved you."
    },
    {
      "type": "gospel",
      "citation": "Mt 18:21-35",
      "summary": "Parable of official who does not show the mercy he received."
    }
  ],
  "antiphons": [
    {
      "type": "entrance",
      "option": 1,
      "citation": "Cf. Sir 36:18",
      "text": "Give peace, O Lord, to those who wait for you,\nthat your prophets be found true.\nHear the prayers of your servant, and of your people Israel."
    },
    {
      "type": "communion",
      "option": 1,
      "citation": "Cf. Ps 36 (35):8",
      "text": "How precious is your mercy, O God!\nThe children of men seek shelter in the shadow of your wings."
    },
    {
      "type": "communion",
      "option": 2,
      "citation": "Roman Missal — Cf. 1 Cor 10:16",
      "text": "The chalice of blessing that we bless\nis a communion in the Blood of Christ;\nand the bread that we break\nis a sharing in the Body of the Lord."
    }
  ],
