  "lectionary": {
    "number": "033•C",
    "gospelTitle": "The Prodigal Son Returns",
    "thematicTag": "Lost–Found 1/3 – Mercy"
  },
  "readings": [
    {
      "type": "first",
      "citation": "Jos 5:9a, 10-12",
      "summary": "The Lord removes the reproach of Egypt."
    },
    {
      "type": "psalm",
      "citation": "Ps 34:2-3, 4-5, 6-7, R. v.9a\nTaste and see the goodness of the Lord.",
      "summary": "",
      "antiphon": "Ps 34:2-3, 4-5, 6-7, R. v.9a\nTaste and see the goodness of the Lord."
    },
    {
      "type": "second",
      "citation": "2 Cor 5:17-21",
      "summary": "All is new in Christ."
    },
    {
      "type": "gospel_verse",
      "citation": "Lk 15:18",
      "summary": "I will get up and go to my Father and shall say to him:\nFather, I have sinned against heaven and against you."
    },
    {
      "type": "gospel",
      "citation": "Lk 15:1-3, 11-32",
      "summary": "Parable of the prodigal son."
    }
  ],
  "antiphons": [
    {
      "type": "entrance",
      "option": 1,
      "citation": "Cf. Is 66:10–11",
      "text": "Rejoice, Jerusalem, and all who love her.\nBe joyful, all who were in mourning;\nexult and be satisfied at her consoling breast."
    },
    {
      "type": "communion",
      "option": 1,
      "citation": "For Lk 15:32 (Prodigal Son)",
      "text": "You must rejoice, my son,\nfor your brother was dead and has come to life;\nhe was lost and is found."
    },
    {
      "type": "communion",
      "option": 2,
      "citation": "Communion Antiphon | For Jn 9:11, 38 (Man Born Blind)",
      "text": "The Lord anointed my eyes: I went, I washed,\nI saw and I believed in God."
    }
  ],
  "planningNotes": [
    "Laetare Sunday - Choir wear rose pink!"
  ],
