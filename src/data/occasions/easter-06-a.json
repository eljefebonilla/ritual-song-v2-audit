  "antiphons": [
    {
      "type": "entrance",
      "option": 1,
      "citation": "Cf. Is 48:20",
      "text": "Proclaim a joyful sound and let it be heard;\nproclaim to the ends of the earth:\nThe Lord has freed his people, alleluia."
    },
    {
      "type": "communion",
      "option": 1,
      "citation": "Jn 14:15–16",
      "text": "If you love me, keep my commandments,\nsays the Lord, and I will ask the Father\nand he will send you another Paraclete,\nto abide with you for ever, alleluia."
    }
  ],
