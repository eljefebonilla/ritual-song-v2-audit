  "lectionary": {
    "number": "005•B",
    "gospelTitle": "John the Baptist Prepares the Way",
    "thematicTag": "Baptist Prologue 1/2"
  },
  "readings": [
    {
      "type": "first",
      "citation": "Is 40:1–5, 9–11",
      "summary": "In the desert make ready the way of the Lord."
    },
    {
      "type": "psalm",
      "citation": "Ps 85:9-10, 11-12, 13-14. R. v.8\nLord, let us see your kindness, and grant us your salvation.",
      "summary": "",
      "antiphon": "Ps 85:9-10, 11-12, 13-14. R. v.8\nLord, let us see your kindness, and grant us your salvation."
    },
    {
      "type": "second",
      "citation": "2 Pt 3:8-14",
      "summary": "The Lord shows great patience."
    },
    {
      "type": "gospel_verse",
      "citation": "Lk 3:4, 6",
      "summary": "Prepare the way of the Lord, make straight his paths:\nall flesh shall see the salvation of God."
    },
    {
      "type": "gospel",
      "citation": "Mk 1:1-8",
      "summary": "John the Baptist proclaims the coming of the Messiah."
    }
  ],
  "antiphons": [
    {
      "type": "entrance",
      "option": 1,
      "citation": "Cf. Is 30:19, 30",
      "text": "O people of Sion, behold,\nthe Lord will come to save the nations,\nand the Lord will make the glory of his voice heard\nin the joy of your heart."
    },
    {
      "type": "communion",
      "option": 1,
      "citation": "Bar 5:5; 4:36",
      "text": "Jerusalem, arise and stand upon the heights,\nand behold the joy which comes to you from God."
    }
  ],
