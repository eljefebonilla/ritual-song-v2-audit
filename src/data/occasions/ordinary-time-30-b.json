  "lectionary": {
    "number": "149•B",
    "gospelTitle": "Bartimaeus: “Master, I want to see.”",
    "thematicTag": "“Go your way; your faith has saved you.”"
  },
  "readings": [
    {
      "type": "first",
      "citation": "Jer 31:7-9",
      "summary": "The Lord declares himself a father to Israel."
    },
    {
      "type": "psalm",
      "citation": "Ps 126:1-2, 2-3, 4-5, 6, R. v.3\nThe Lord has done great things for us;\nwe are filled with joy.",
      "summary": "",
      "antiphon": "Ps 126:1-2, 2-3, 4-5, 6, R. v.3\nThe Lord has done great things for us;\nwe are filled with joy."
    },
    {
      "type": "second",
      "citation": "Heb 5:1-6",
      "summary": "The Lord himself calls those who are to serve."
    },
    {
      "type": "gospel_verse",
      "citation": "See 2 Tim 1:10",
      "summary": "Our Savior Jesus Christ destroyed death\nand brought life to light through the Gospel."
    },
    {
      "type": "gospel",
      "citation": "Mk 10:46-52",
      "summary": "Jesus gives sight to Bartimaeus."
    }
  ],
  "antiphons": [
    {
      "type": "entrance",
      "option": 1,
      "citation": "Cf. Ps 105 (104):3–4",
      "text": "Let the hearts that seek the Lord rejoice;\nturn to the Lord and his strength; constantly seek his face."
    },
    {
      "type": "communion",
      "option": 1,
      "citation": "Cf. Ps 20 (19):6",
      "text": "We will ring out our joy at your saving help\nand exult in the name of our God."
    },
    {
      "type": "communion",
      "option": 2,
      "citation": "Roman Missal — Eph 5:2",
      "text": "Christ loved us and gave himself up for us,\nas a fragrant offering to God."
    }
  ],
