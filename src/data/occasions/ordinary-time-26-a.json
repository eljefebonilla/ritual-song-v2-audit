  "antiphons": [
    {
      "type": "entrance",
      "option": 1,
      "citation": "Dn 3:31, 29, 30, 43, 42",
      "text": "All that you have done to us, O Lord,\nyou have done with true judgment,\nfor we have sinned against you\nand not obeyed your commandments.\nBut give glory to your name\nand deal with us according to the bounty of your mercy."
    },
    {
      "type": "communion",
      "option": 1,
      "citation": "Cf. Ps 119 (118):49–50",
      "text": "Remember your word to your servant, O Lord,\nby which you have given me hope.\nThis is my comfort when I am brought low."
    },
    {
      "type": "communion",
      "option": 2,
      "citation": "Roman Missal — 1 Jn 3:16",
      "text": "By this we came to know the love of God:\nthat Christ laid down his life for us;\nso we ought to lay down our lives for one another."
    }
