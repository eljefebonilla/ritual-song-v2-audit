      "type": "first",
      "citation": "Mal 1:14b—2:2b, 8-10",
      "summary": "One God created us all, is Father to us all."
    },
    {
      "type": "psalm",
      "citation": "Ps 131:1, 2, 3\nIn you, Lord, I have found my peace.",
      "summary": "",
      "antiphon": "Ps 131:1, 2, 3\nIn you, Lord, I have found my peace."
    },
    {
      "type": "second",
      "citation": "1 Thes 2:7b-9, 13",
      "summary": "Paul thanks God that their preaching was well received."
    },
    {
      "type": "gospel_verse",
      "citation": "Mt 23:9b, 10b",
      "summary": "You have but one Father in heaven\nand one master, the Christ."
    },
    {
      "type": "gospel",
      "citation": "Mt 23:1-12",
      "summary": "Those who humble themselves shall be exalted."
    }
  ],
  "antiphons": [
    {
      "type": "entrance",
      "option": 1,
      "citation": "Cf. Ps 38 (37):22–23",
      "text": "Forsake me not, O Lord, my God;\nbe not far from me!\nMake haste and come to my help,\nO Lord, my strong salvation!"
    },
    {
      "type": "communion",
      "option": 1,
      "citation": "Cf. Ps 16 (15):11",
      "text": "You will show me the path of life,\nthe fullness of joy in your presence, O Lord."
    },
    {
      "type": "communion",
      "option": 2,
      "citation": "Roman Missal — Jn 6:58",
      "text": "Just as the living Father sent me\nand I have life because of the Father,\nso whoever feeds on me\nshall have life because of me, says the Lord."
    }
  ],
