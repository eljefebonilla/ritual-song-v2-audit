      "type": "entrance",
      "option": 1,
      "citation": "Cf. Ps 86 (85):1–3",
      "text": "Turn your ear, O Lord, and answer me;\nsave the servant who trusts in you, my God.\nHave mercy on me, O Lord, for I cry to you all the day long."
    },
    {
      "type": "communion",
      "option": 1,
      "citation": "Cf. Ps 104 (103):13–15",
      "text": "The earth is replete with the fruits of your work, O Lord;\nyou bring forth bread from the earth\nand wine to cheer the heart."
    },
    {
      "type": "communion",
      "option": 2,
      "citation": "Roman Missal — Cf. Jn 6:54",
      "text": "Whoever eats my flesh and drinks my blood\nhas eternal life, says the Lord,\nand I will raise him up on the last day."
    }
  ],
