    },
    {
      "type": "communion",
      "option": 2,
      "citation": "Communion Antiphon • Option II | Mt 5:3–4",
      "text": "Blessed are the poor in spirit,\nfor theirs is the Kingdom of Heaven.\nBlessed are the meek, for they shall possess the land."
    }
