  "lectionary": {
    "number": "006•C",
    "gospelTitle": "All Flesh Shall See Salvation",
    "thematicTag": "Baptist Advent 1/2 – Isaiah Prep"
  },
  "readings": [
    {
      "type": "first",
      "citation": "Bar 5:1-9",
      "summary": "Take off your robe of mourning, put on the splendor of glory."
    },
    {
      "type": "psalm",
      "citation": "Ps 126:1-2, 2-3, 4-5, 6, R. v.3\nThe Lord has done great things for us;\nwe are filled with joy.",
      "summary": "",
      "antiphon": "Ps 126:1-2, 2-3, 4-5, 6, R. v.3\nThe Lord has done great things for us;\nwe are filled with joy."
    },
    {
      "type": "second",
      "citation": "Phil 1:4-6. 8-11",
      "summary": "He who has begun the good work in you will bring it to completion."
    },
    {
      "type": "gospel_verse",
      "citation": "Lk 3:4, 6",
      "summary": "Prepare the way of the Lord, make straight his paths:\nall flesh shall see the salvation of God."
    },
    {
      "type": "gospel",
      "citation": "Lk 3:1-6",
      "summary": "John the Baptist proclaims a baptism of repentance."
    }
  ],
  "antiphons": [
    {
      "type": "entrance",
      "option": 1,
      "citation": "Cf. Is 30:19, 30",
      "text": "O people of Sion, behold,\nthe Lord will come to save the nations,\nand the Lord will make the glory of his voice heard\nin the joy of your heart."
    },
    {
      "type": "communion",
      "option": 1,
      "citation": "Bar 5:5; 4:36",
      "text": "Jerusalem, arise and stand upon the heights,\nand behold the joy which comes to you from God."
    }
  ],
