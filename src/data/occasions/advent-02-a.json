  "lectionary": {
    "number": "004•A",
    "gospelTitle": "Prepare the Way: John the Baptist",
    "thematicTag": "Baptist Call 1/2"
  },
  "readings": [
    {
      "type": "first",
      "citation": "Is 11:1–10",
      "summary": "A shoot shall sprout from the stump of Jesse.\nPeace and justice will triumph."
    },
    {
      "type": "psalm",
      "citation": "Ps 72:1-2, 7-8, 12-13, 17, R. see v.7\nJustice shall flourish in his time,\nand fullness of peace for ever.",
      "summary": "",
      "antiphon": "Ps 72:1-2, 7-8, 12-13, 17, R. see v.7\nJustice shall flourish in his time,\nand fullness of peace for ever."
    },
    {
      "type": "second",
      "citation": "Rom 15:4-9",
      "summary": "Live in harmony with one another."
    },
    {
      "type": "gospel_verse",
      "citation": "Lk 3:4, 6",
      "summary": "Prepare the way of the Lord, make straight his paths:\nall flesh shall see the salvation of God."
    },
    {
      "type": "gospel",
      "citation": "Mt 3:1-12",
      "summary": "John the Baptist begins to preach in the desert."
    }
  ],
  "antiphons": [
    {
      "type": "entrance",
      "option": 1,
      "citation": "Cf. Is 30:19, 30",
      "text": "O people of Sion, behold,\nthe Lord will come to save the nations,\nand the Lord will make the glory of his voice heard\nin the joy of your heart."
    },
    {
      "type": "communion",
      "option": 1,
      "citation": "Bar 5:5; 4:36",
      "text": "Jerusalem, arise and stand upon the heights,\nand behold the joy which comes to you from God."
    }
  ],
