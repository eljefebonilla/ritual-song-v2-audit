      "summary": "",
      "antiphon": "Lk 1:46-48, 49-50, 53-54, R. Is 61:10b\nMy soul rejoices in my God."
    },
    {
      "type": "second",
      "citation": "1 Thes 5:16-24",
      "summary": "Rejoice and pray always."
    },
    {
      "type": "gospel_verse",
      "citation": "Is 61:1 (cited in Lk 4:18)",
      "summary": "The Spirit of the Lord is upon me,\nbecause he has anointed me\nto bring glad tidings to the poor."
    },
    {
      "type": "gospel",
      "citation": "Jn 1:6-8, 19-28",
      "summary": "The priests and Levites question John's identity."
    }
  ],
