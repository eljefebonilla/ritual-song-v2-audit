  "readings": [
    {
      "type": "first",
      "citation": "Is 43:16-21",
      "summary": "God has done and will continue to do great things."
    },
    {
      "type": "psalm",
      "citation": "Ps 126:1-2, 2-3, 4-5, 6, R. v.3\nThe Lord has done great things for us;\nwe are filled with joy.",
      "summary": "",
      "antiphon": "Ps 126:1-2, 2-3, 4-5, 6, R. v.3\nThe Lord has done great things for us;\nwe are filled with joy."
    },
    {
      "type": "second",
      "citation": "Phil 3:8-14",
      "summary": "Paul forfeits all for Christ."
    },
    {
      "type": "gospel_verse",
      "citation": "Jl 2:12-13",
      "summary": "Even now, says the Lord,\nreturn to me with your whole heart;\nfor I am gracious and merciful."
    },
    {
      "type": "gospel",
      "citation": "Jn 8:1-11",
      "summary": "The Pharisees confront Jesus with an adulteress."
    }
  ],
  "antiphons": [
    {
      "type": "entrance",
      "option": 1,
      "citation": "Cf. Ps 43 (42):1–2",
      "text": "Give me justice, O God,\nand plead my cause against a nation that is faithless.\nFrom the deceitful and cunning rescue me,\nfor you, O God, are my strength."
    },
    {
      "type": "communion",
      "option": 1,
      "citation": "For Jn 8:10–11 (Adulterous Woma)",
      "text": "Has no one condemned you, woman? No one, Lord.\nNeither shall I condemn you. From now on, sin no more."
    }
  ],
