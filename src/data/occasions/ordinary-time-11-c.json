  },
  "readings": [
    {
      "type": "first",
      "citation": "2 Sam 12:7–10, 13",
      "summary": "The Lord has forgiven your sin; you shall not die."
    },
    {
      "type": "psalm",
      "citation": "Ps 32:1–2, 5, 7, 11\nLord, forgive the wrong I have done.",
      "summary": "",
      "antiphon": "Ps 32:1–2, 5, 7, 11\nLord, forgive the wrong I have done."
    },
    {
      "type": "second",
      "citation": "Gal 2:16, 19–21",
      "summary": "I live, no longer I, but Christ lives in me."
    },
    {
      "type": "gospel_verse",
      "citation": "1 Jn 4:10b",
      "summary": "God loved us and sent his Son\nas expiation for our sins."
    },
    {
      "type": "gospel",
      "citation": "Lk 7:36–8:3 (Shorter - Lk 7:36–50)",
      "summary": "Her sins have been forgiven, because she has shown great love."
    }
  ],
  "antiphons": [
    {
      "type": "entrance",
      "option": 1,
      "citation": "Cf. Ps 27 (26):7, 9",
      "text": "O Lord, hear my voice, for I have called to you; be my help.\nDo not abandon or forsake me, O God, my Savior!"
    },
    {
      "type": "communion",
      "option": 1,
      "citation": "Ps 27 (26):4",
      "text": "There is one thing I ask of the Lord, only this do I seek:\nto live in the house of the Lord all the days of my life."
    },
    {
      "type": "communion",
      "option": 2,
      "citation": "Communion Antiphon • Option II | Jn 17:11",
      "text": "Holy Father, keep in your name those you have given me,\nthat they may be one as we are one, says the Lord."
    }
  ],
