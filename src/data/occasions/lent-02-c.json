  "lectionary": {
    "number": "027•C",
    "gospelTitle": "Jesus Is Transfigured",
    "thematicTag": "Glory Preview of Cross"
  },
  "readings": [
    {
      "type": "first",
      "citation": "Gen 15:5-12, 17-18",
      "summary": "The Lord establishes a covenant with Abraham."
    },
    {
      "type": "psalm",
      "citation": "Ps 27:1, 7-8, 8-9, 13-14, R. v.1a\nThe Lord is my light and my salvation.",
      "summary": "",
      "antiphon": "Ps 27:1, 7-8, 8-9, 13-14, R. v.1a\nThe Lord is my light and my salvation."
    },
    {
      "type": "second",
      "citation": "Phil 3:17 – 4:1 (Shorter - 3:20 – 4:1)",
      "summary": "Our citizenship is in heaven."
    },
    {
      "type": "gospel_verse",
      "citation": "Mt 17:5",
      "summary": "From the shining cloud the Father’s voice is heard:\nThis is my beloved Son, hear him."
    },
    {
      "type": "gospel",
      "citation": "Lk 9:28b-36",
      "summary": "Jesus is transfigured before Peter, James, and John."
    }
  ],
  "antiphons": [
    {
      "type": "entrance",
      "option": 1,
      "citation": "Cf. Ps 27 (26):8–9]",
      "text": "Of you my heart has spoken: Seek his face.\nIt is your face, O Lord, that I seek;\nhide not your face from me."
    },
    {
      "type": "entrance",
      "option": 2,
      "citation": "Entrance Antiphon • Option II | Ps 25 (24):6, 2, 22",
      "text": "Remember your compassion, O Lord,\nand your merciful love, for they are from of old.\nLet not our enemies exult over us.\nRedeem us, O God of Israel, from all our distress."
    },
    {
      "type": "communion",
      "option": 1,
      "citation": "Cf. Mt 17:5",
      "text": "This is my beloved Son,\nwith whom I am well pleased;\nlisten to him."
    }
  ],
  "planningNotes": [
    "⏰ DST - 2028 - MAR 12 - LOSE HOUR"
  ],
